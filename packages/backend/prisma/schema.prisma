generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  ACCOUNTANT
  STAFF
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

enum NormalBalance {
  DEBIT
  CREDIT
}

enum EntryStatus {
  DRAFT
  POSTED
  REVERSED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  PARTIALLY_PAID
  OVERDUE
  CANCELLED
}

enum ExpenseStatus {
  PENDING
  APPROVED
  REJECTED
  PAID
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  CREDIT_CARD
  CHECK
  OTHER
}

enum StockMovementType {
  PURCHASE
  SALE
  ADJUSTMENT_IN
  ADJUSTMENT_OUT
  RETURN_IN
  RETURN_OUT
  WRITE_OFF
}

enum PurchaseOrderStatus {
  DRAFT
  SENT
  RECEIVED
  PARTIALLY_RECEIVED
  CANCELLED
}

// ─── Users & Auth ─────────────────────────────────────────────────────────────

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  name         String
  passwordHash String
  role         Role      @default(STAFF)
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  journalEntries JournalEntry[]
  invoices       Invoice[]
  expenses       Expense[]
  auditLogs      AuditLog[]
  purchaseOrders PurchaseOrder[]

  @@map("users")
  @@index([email])
}

// ─── Chart of Accounts ────────────────────────────────────────────────────────

model Account {
  id            String        @id @default(uuid())
  code          String        @unique
  name          String
  type          AccountType
  subtype       String?
  normalBalance NormalBalance
  description   String?
  isActive      Boolean       @default(true)
  parentId      String?
  parent        Account?      @relation("AccountHierarchy", fields: [parentId], references: [id])
  children      Account[]     @relation("AccountHierarchy")

  journalLines JournalEntryLine[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("accounts")
  @@index([code])
  @@index([type])
  @@index([parentId])
}

// ─── Journal Entries (Core Double-Entry) ──────────────────────────────────────

model JournalEntry {
  id          String      @id @default(uuid())
  entryNumber String      @unique
  date        DateTime    @db.Date
  description String
  reference   String?
  sourceType  String?     // invoice, expense, payment, manual, inventory
  sourceId    String?     // FK to source record
  status      EntryStatus @default(POSTED)
  isReversed  Boolean     @default(false)
  reversalId  String?     // UUID of the reversal entry
  reversalOf  String?     // UUID of the entry this reverses

  lines JournalEntryLine[]

  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("journal_entries")
  @@index([date])
  @@index([entryNumber])
  @@index([sourceType, sourceId])
  @@index([createdById])
}

model JournalEntryLine {
  id             String       @id @default(uuid())
  journalEntryId String
  journalEntry   JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  accountId      String
  account        Account      @relation(fields: [accountId], references: [id])
  description    String?
  debit          Decimal      @default(0) @db.Decimal(15, 2)
  credit         Decimal      @default(0) @db.Decimal(15, 2)
  sortOrder      Int          @default(0)

  @@map("journal_entry_lines")
  @@index([journalEntryId])
  @@index([accountId])
}

// ─── Customers ────────────────────────────────────────────────────────────────

model Customer {
  id            String   @id @default(uuid())
  code          String   @unique
  name          String
  email         String?
  phone         String?
  address       String?
  city          String?
  country       String?
  taxId         String?
  creditLimit   Decimal? @db.Decimal(15, 2)
  paymentTerms  Int      @default(30) // days
  isActive      Boolean  @default(true)
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  invoices Invoice[]

  @@map("customers")
  @@index([name])
  @@index([email])
  @@index([code])
}

// ─── Suppliers ────────────────────────────────────────────────────────────────

model Supplier {
  id           String   @id @default(uuid())
  code         String   @unique
  name         String
  email        String?
  phone        String?
  address      String?
  city         String?
  country      String?
  taxId        String?
  paymentTerms Int      @default(30)
  isActive     Boolean  @default(true)
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  expenses       Expense[]
  purchaseOrders PurchaseOrder[]
  movements      InventoryMovement[]

  @@map("suppliers")
  @@index([name])
  @@index([code])
}

// ─── Invoicing ────────────────────────────────────────────────────────────────

model Invoice {
  id            String        @id @default(uuid())
  invoiceNumber String        @unique
  customerId    String
  customer      Customer      @relation(fields: [customerId], references: [id])
  date          DateTime      @db.Date
  dueDate       DateTime      @db.Date
  status        InvoiceStatus @default(DRAFT)
  subtotal      Decimal       @db.Decimal(15, 2)
  taxAmount     Decimal       @default(0) @db.Decimal(15, 2)
  discountAmount Decimal      @default(0) @db.Decimal(15, 2)
  total         Decimal       @db.Decimal(15, 2)
  amountPaid    Decimal       @default(0) @db.Decimal(15, 2)
  balanceDue    Decimal       @db.Decimal(15, 2)
  notes         String?
  terms         String?
  currency      String        @default("USD")
  journalEntryId String?

  items    InvoiceItem[]
  payments Payment[]

  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("invoices")
  @@index([invoiceNumber])
  @@index([customerId])
  @@index([status])
  @@index([dueDate])
  @@index([date])
}

model InvoiceItem {
  id              String         @id @default(uuid())
  invoiceId       String
  invoice         Invoice        @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  inventoryItemId String?
  inventoryItem   InventoryItem? @relation(fields: [inventoryItemId], references: [id])
  description     String
  quantity        Decimal        @db.Decimal(10, 3)
  unitPrice       Decimal        @db.Decimal(15, 2)
  discountPct     Decimal        @default(0) @db.Decimal(5, 2)
  taxRate         Decimal        @default(0) @db.Decimal(5, 2)
  amount          Decimal        @db.Decimal(15, 2) // qty * unit_price * (1-discount)
  sortOrder       Int            @default(0)

  @@map("invoice_items")
  @@index([invoiceId])
  @@index([inventoryItemId])
}

// ─── Payments ─────────────────────────────────────────────────────────────────

model Payment {
  id             String        @id @default(uuid())
  paymentNumber  String        @unique
  invoiceId      String?
  invoice        Invoice?      @relation(fields: [invoiceId], references: [id])
  amount         Decimal       @db.Decimal(15, 2)
  date           DateTime      @db.Date
  method         PaymentMethod
  reference      String?
  notes          String?
  journalEntryId String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@map("payments")
  @@index([invoiceId])
  @@index([date])
}

// ─── Expenses ─────────────────────────────────────────────────────────────────

model Expense {
  id             String        @id @default(uuid())
  expenseNumber  String        @unique
  supplierId     String?
  supplier       Supplier?     @relation(fields: [supplierId], references: [id])
  expenseAccountId String      // Which expense account to debit
  paymentAccountId String      // Which asset/liability account to credit (cash, bank, AP)
  date           DateTime      @db.Date
  amount         Decimal       @db.Decimal(15, 2)
  taxAmount      Decimal       @default(0) @db.Decimal(15, 2)
  total          Decimal       @db.Decimal(15, 2)
  description    String
  category       String?
  status         ExpenseStatus @default(PENDING)
  receiptUrl     String?
  paymentMethod  PaymentMethod?
  journalEntryId String?
  notes          String?

  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("expenses")
  @@index([date])
  @@index([status])
  @@index([category])
  @@index([supplierId])
}

// ─── Inventory ────────────────────────────────────────────────────────────────

model InventoryItem {
  id               String   @id @default(uuid())
  sku              String   @unique
  name             String
  description      String?
  category         String?
  unit             String   @default("unit")
  costPrice        Decimal  @db.Decimal(15, 2)
  sellingPrice     Decimal  @db.Decimal(15, 2)
  quantityOnHand   Decimal  @default(0) @db.Decimal(10, 3)
  reorderLevel     Decimal  @default(0) @db.Decimal(10, 3)
  // Account links
  assetAccountId   String?  // Inventory asset account (1300s)
  cogsAccountId    String?  // Cost of goods sold account (5000s)
  revenueAccountId String?  // Revenue account (4000s)
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  movements    InventoryMovement[]
  invoiceItems InvoiceItem[]
  purchaseOrderItems PurchaseOrderItem[]

  @@map("inventory_items")
  @@index([sku])
  @@index([name])
  @@index([category])
}

model InventoryMovement {
  id              String            @id @default(uuid())
  inventoryItemId String
  inventoryItem   InventoryItem     @relation(fields: [inventoryItemId], references: [id])
  type            StockMovementType
  quantity        Decimal           @db.Decimal(10, 3) // + = in, - = out
  unitCost        Decimal           @db.Decimal(15, 2)
  totalCost       Decimal           @db.Decimal(15, 2)
  quantityBefore  Decimal           @db.Decimal(10, 3)
  quantityAfter   Decimal           @db.Decimal(10, 3)
  date            DateTime          @db.Date
  reference       String?
  supplierId      String?
  supplier        Supplier?         @relation(fields: [supplierId], references: [id])
  journalEntryId  String?
  notes           String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@map("inventory_movements")
  @@index([inventoryItemId])
  @@index([date])
  @@index([type])
}

// ─── Purchase Orders ──────────────────────────────────────────────────────────

model PurchaseOrder {
  id              String              @id @default(uuid())
  poNumber        String              @unique
  supplierId      String
  supplier        Supplier            @relation(fields: [supplierId], references: [id])
  date            DateTime            @db.Date
  expectedDate    DateTime?           @db.Date
  status          PurchaseOrderStatus @default(DRAFT)
  subtotal        Decimal             @db.Decimal(15, 2)
  taxAmount       Decimal             @default(0) @db.Decimal(15, 2)
  total           Decimal             @db.Decimal(15, 2)
  notes           String?
  journalEntryId  String?

  items PurchaseOrderItem[]

  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("purchase_orders")
  @@index([poNumber])
  @@index([supplierId])
  @@index([status])
}

model PurchaseOrderItem {
  id              String        @id @default(uuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])
  description     String
  quantity        Decimal       @db.Decimal(10, 3)
  unitCost        Decimal       @db.Decimal(15, 2)
  taxRate         Decimal       @default(0) @db.Decimal(5, 2)
  amount          Decimal       @db.Decimal(15, 2)
  quantityReceived Decimal      @default(0) @db.Decimal(10, 3)
  sortOrder       Int           @default(0)

  @@map("purchase_order_items")
  @@index([purchaseOrderId])
  @@index([inventoryItemId])
}

// ─── Audit Logs ───────────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  action     String   // CREATE, UPDATE, DELETE, VIEW, LOGIN, LOGOUT, POST_ENTRY, REVERSE
  entity     String   // Table/model name
  entityId   String?
  oldValues  Json?
  newValues  Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@map("audit_logs")
  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
  @@index([action])
}
